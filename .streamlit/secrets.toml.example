# AlphaLens — Streamlit Secrets Template
#
# For Streamlit Cloud deployment:
#   1. Copy this file content into your app's "Secrets" section in
#      the Streamlit Cloud dashboard (NOT as a committed file)
#   2. For local development: copy to .streamlit/secrets.toml (gitignored)
#
# All three keys are required for full functionality.
# The app degrades gracefully if Alpha Vantage or FRED are missing,
# but GOOGLE_API_KEY is mandatory for LLM calls.

# ── Required ──────────────────────────────────────────────────────────────────
# Get free at: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY = "your_google_api_key_here"

# ── Recommended ───────────────────────────────────────────────────────────────
# Get free at: https://www.alphavantage.co/support/#api-key (25 req/day free)
ALPHA_VANTAGE_API_KEY = "your_alpha_vantage_key_here"

# Get free at: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY = "your_fred_api_key_here"
